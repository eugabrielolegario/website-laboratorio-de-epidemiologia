<script>
// ── Generic slider factory ──
function initSlider(opts: {
  trackId: string; prevId: string; nextId: string; dotsId: string;
  dotClass: string; perView: (vw: number) => number;
}) {
  const track = document.getElementById(opts.trackId) as HTMLElement | null;
  const prevBtn = document.getElementById(opts.prevId) as HTMLButtonElement | null;
  const nextBtn = document.getElementById(opts.nextId) as HTMLButtonElement | null;
  const dotsEl = document.getElementById(opts.dotsId);
  if (!track) return;

  const cards = track.children;
  let current = 0;

  function perView() {
    return opts.perView(window.innerWidth);
  }
  function maxIdx() { return Math.max(0, cards.length - perView()); }
  function buildDots() {
    if (!dotsEl) return;
    dotsEl.replaceChildren();
    const total = maxIdx() + 1;
    for (let i = 0; i < total; i++) {
      const d = document.createElement('div');
      d.className = opts.dotClass + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goTo(i));
      dotsEl.appendChild(d);
    }
  }
  function updateDots() {
    if (!dotsEl) return;
    const dots = dotsEl.querySelectorAll('.' + opts.dotClass.split(' ')[0]);
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }
  function goTo(idx: number) {
    current = Math.max(0, Math.min(idx, maxIdx()));
    const cardWidth = (cards[0] as HTMLElement).offsetWidth + 20;
    track.style.transform = `translateX(-${current * cardWidth}px)`;
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current >= maxIdx();
    updateDots();
  }
  if (prevBtn) prevBtn.addEventListener('click', () => goTo(current - 1));
  if (nextBtn) nextBtn.addEventListener('click', () => goTo(current + 1));
  let touchStartX = 0;
  track.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', (e: TouchEvent) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
  });
  buildDots();
  goTo(0);
  window.addEventListener('resize', () => { buildDots(); goTo(Math.min(current, maxIdx())); });
}

initSlider({
  trackId: 'ebookTrack', prevId: 'ebookPrev', nextId: 'ebookNext', dotsId: 'ebookDots',
  dotClass: 'ebook-slider-dot',
  perView: (vw) => vw <= 480 ? 1 : vw <= 768 ? 2 : vw <= 900 ? 3 : 4
});
</script>


</BaseLayout>
