<script>
  // Slider v2
  const track = document.getElementById('v2Track') as HTMLElement | null;
  const prevBtn = document.getElementById('v2Prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('v2Next') as HTMLButtonElement | null;
  const dotsEl = document.getElementById('v2Dots');
  if (track) {
    const cards = Array.from(track.children) as HTMLElement[];
    let current = 0;
    const perView = () => window.innerWidth <= 768 ? 1 : 2;
    const maxIdx = () => Math.max(0, cards.length - perView());

    function buildDots() {
      if (!dotsEl) return;
      dotsEl.innerHTML = '';
      for (let i = 0; i <= maxIdx(); i++) {
        const d = document.createElement('div');
        d.className = 'v2-slider-dot' + (i === 0 ? ' active' : '');
        d.addEventListener('click', () => goTo(i));
        dotsEl.appendChild(d);
      }
    }
    function updateDots() {
      dotsEl?.querySelectorAll('.v2-slider-dot').forEach((d, i) =>
        d.classList.toggle('active', i === current)
      );
    }
    function goTo(idx: number) {
      current = Math.max(0, Math.min(idx, maxIdx()));
      const w = cards[0].offsetWidth + 20;
      track.style.transform = `translateX(-${current * w}px)`;
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current >= maxIdx();
      updateDots();
    }
    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    let tx = 0;
    track.addEventListener('touchstart', (e: TouchEvent) => { tx = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e: TouchEvent) => {
      const diff = tx - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
    });
    buildDots();
    goTo(0);
    window.addEventListener('resize', () => { buildDots(); goTo(Math.min(current, maxIdx())); });
  }
</script>

</BaseLayout>
