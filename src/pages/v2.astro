<!-- ══════════════════════════════════════════
     AUTORIDADE — LUCAS
══════════════════════════════════════════ -->
<section class="v2-authority">
  <div class="container">
    <div class="v2-authority-grid">

      <div class="v2-authority-photo-wrap">
        <div class="v2-authority-photo">
          <img src="/assets/images/lucas-santos.jpg" alt="Lucas Santos" loading="lazy"
               onerror="this.parentElement.classList.add('v2-authority-photo--fallback')" />
          <div class="v2-authority-photo-fallback" aria-hidden="true">
            <svg viewBox="0 0 200 260" fill="none" width="100%" height="100%">
              <rect width="200" height="260" fill="#0f1245"/>
              <circle cx="100" cy="90" r="44" fill="#99ffcd" opacity="0.08"/>
              <circle cx="100" cy="90" r="30" fill="#99ffcd" opacity="0.1"/>
              <path d="M40 220 C40 180 68 160 100 160 C132 160 160 180 160 220" fill="#99ffcd" opacity="0.06"/>
              <text x="100" y="250" font-size="10" fill="#7a85b8" text-anchor="middle" font-family="sans-serif">Lucas Santos</text>
            </svg>
          </div>
        </div>
        <div class="v2-authority-badge">
          <div class="v2-dot v2-dot--amber"></div>
          <div>
            <strong>Publicado no The Lancet</strong>
            <span>Colaborador Sênior, GBD · IHME</span>
          </div>
        </div>
      </div>

      <div class="v2-authority-content">
        <div class="section-tag">Quem está por trás</div>
        <h2 class="v2-h2">Aprenda com quem publicou<br/>no <span class="mint">The Lancet.</span></h2>
        <p>Lucas Santos é epidemiologista, clínico e supervisor clínico. Cofundador e autoridade técnica do LabEpi.</p>
        <p>Sua participação no Global Burden of Disease — o maior estudo epidemiológico colaborativo do mundo, coordenado pelo IHME da Universidade de Washington — sustenta cada conteúdo que o LabEpi produz.</p>
        <div class="v2-creds">
          <div class="v2-cred">
            <span class="v2-cred-icon">◉</span>
            Colaborador Sênior do GBD, IHME / Universidade de Washington
          </div>
          <div class="v2-cred">
            <span class="v2-cred-icon">◉</span>
