---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.date <= now))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' });
}
function readingTime(body: string) {
  return Math.ceil(body.split(/\s+/).length / 200);
}
---
<BaseLayout title="Laboratório de Epidemiologia — Epidemiologia Aplicada no Brasil">

<!-- ══════════════════════════════════════════
     HERO
══════════════════════════════════════════ -->
<section class="v2-hero">
  <div class="v2-hero-orb v2-hero-orb-1" aria-hidden="true"></div>
  <div class="v2-hero-orb v2-hero-orb-2" aria-hidden="true"></div>

  <div class="container">
    <div class="v2-hero-inner">
      <div class="v2-hero-badge">
        <span class="v2-dot v2-dot--mint"></span>
        Hub de Epidemiologia Aplicada no Brasil
      </div>
      <h1 class="v2-hero-h1">
        Para quem quer<br/>
        pesquisar de <em>verdade.</em>
      </h1>
      <p class="v2-hero-sub">
        Do delineamento à publicação. Com rigor técnico, base científica e quem já publicou no maior estudo de saúde do mundo.
      </p>
      <div class="v2-hero-actions">
        <a href="#lead-magnet" class="v2-btn-primary">
          <svg width="15" height="15" viewBox="0 0 14 14" fill="none"><path d="M7 1v8M4 6l3 3 3-3M1 10v1a2 2 0 002 2h8a2 2 0 002-2v-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Baixe o Guia Grátis
        </a>
        <a href="/sobre/" class="v2-btn-ghost">Conheça o LabEpi</a>
      </div>

      <!-- Hero visual / placeholder -->
      <div class="v2-hero-visual" aria-hidden="true">
        <div class="v2-hero-card v2-hero-card--lg">
          <div class="v2-hero-card-tag">Global Burden of Disease</div>
          <div class="v2-hero-card-line"></div>
          <svg class="v2-hero-chart" viewBox="0 0 200 60" fill="none">
            <polyline points="0,50 30,38 60,42 90,20 120,28 150,10 180,15 200,8"
              stroke="#99ffcd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <polyline points="0,50 30,38 60,42 90,20 120,28 150,10 180,15 200,8 200,60 0,60"
              fill="url(#chartGrad)" opacity="0.2"/>
            <defs>
              <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#99ffcd"/>
                <stop offset="100%" stop-color="transparent"/>
              </linearGradient>
            </defs>
          </svg>
          <div class="v2-hero-card-meta">
            <span>600+ citações</span><span>·</span><span>The Lancet</span>
          </div>
        </div>
        <div class="v2-hero-card-stack">
          <div class="v2-hero-card v2-hero-card--sm">
            <span class="v2-hero-card-num">2,3M</span>
            <span class="v2-hero-card-lbl">pesquisadores de saúde no Brasil</span>
          </div>
          <div class="v2-hero-card v2-hero-card--sm v2-hero-card--accent">
            <span class="v2-hero-card-num v2-hero-card-num--mint">GBD</span>
            <span class="v2-hero-card-lbl">maior estudo epidemiológico do mundo</span>
          </div>
          <div class="v2-hero-card v2-hero-card--sm">
            <span class="v2-hero-card-num">150+</span>
            <span class="v2-hero-card-lbl">países impactados</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     STATS BAR
══════════════════════════════════════════ -->
<div class="v2-statsbar">
  <div class="container">
    <div class="v2-statsbar-grid">
      <div class="v2-statitem">
        <span class="v2-statitem-val">GBD</span>
