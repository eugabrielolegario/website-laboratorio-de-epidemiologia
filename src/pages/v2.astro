            <text x="108" y="292" font-size="9" fill="#7a85b8" text-anchor="middle" font-family="sans-serif">2020</text>
            <text x="168" y="292" font-size="9" fill="#99ffcd" text-anchor="middle" font-family="sans-serif">2021</text>
            <text x="228" y="292" font-size="9" fill="#99ffcd" text-anchor="middle" font-family="sans-serif">2022</text>
            <text x="288" y="292" font-size="9" fill="#7a85b8" text-anchor="middle" font-family="sans-serif">2023</text>
            <text x="348" y="292" font-size="9" fill="#7a85b8" text-anchor="middle" font-family="sans-serif">2024</text>
            <!-- Tag -->
            <rect x="12" y="12" width="160" height="24" rx="6" fill="#99ffcd" fill-opacity="0.12"/>
