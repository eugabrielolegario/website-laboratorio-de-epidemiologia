<!-- ══════════════════════════════════════════
     CURSOS — SLIDER
══════════════════════════════════════════ -->
<section class="v2-cursos">
  <div class="container">
    <div class="v2-cursos-head">
      <div>
        <div class="v2-em-breve">
          <svg width="6" height="6" viewBox="0 0 6 6" fill="#ffd36e"><circle cx="3" cy="3" r="3"/></svg>
          Em breve · 2026
        </div>
        <div class="section-tag">Cursos &amp; Formação</div>
        <h2 class="v2-h2">Do <span class="mint">fundamento</span><br/>à publicação.</h2>
      </div>
      <div class="v2-slider-nav">
        <button class="v2-slider-btn" id="v2Prev" aria-label="Anterior">
