              <a href="#" class="v2-link-arrow" style="font-size:13px;">Avise-me <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
