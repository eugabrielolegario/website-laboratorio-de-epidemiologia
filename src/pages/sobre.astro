---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Sobre — Laboratório de Epidemiologia"
  description="Conheça o Laboratório de Epidemiologia: nossa origem, missão, valores, equipe e impacto na formação científica brasileira."
>

<section class="page-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <svg viewBox="0 0 1200 600" fill="none" preserveAspectRatio="xMidYMid slice">
      <circle cx="900" cy="300" r="350" stroke="#99ffcd" stroke-width="1" stroke-dasharray="6 6"/>
      <circle cx="900" cy="300" r="250" stroke="#99ffcd" stroke-width="1" stroke-dasharray="6 6"/>
      <circle cx="900" cy="300" r="150" stroke="#99ffcd" stroke-width="1"/>
      <path d="M900 -50 A350 350 0 0 1 1250 300" stroke="#99ffcd" stroke-width="4" stroke-linecap="round" opacity="0.6"/>
    </svg>
  </div>
  <div class="page-hero-glow" aria-hidden="true"></div>

  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">›</span>
      <span class="breadcrumb-current">Sobre</span>
    </div>

    <div class="page-hero-eyebrow">
      <span></span>
      Quem somos
    </div>

    <h1>
      A ciência epidemiológica<br/>
      ao alcance de <span class="mint">quem quer aprender.</span>
    </h1>

    <p class="page-hero-body">
      O Laboratório de Epidemiologia nasceu para fechar uma lacuna que pesquisadores e estudantes de saúde sempre enfrentaram: conteúdo técnico rigoroso que também é acessível, prático e aplicável na vida real.
    </p>

    <div class="page-hero-stats">
      <div class="hero-stat-item">
        <div class="hero-stat-val">2,3M</div>
        <div class="hero-stat-lbl">estudantes de saúde<br/>no Brasil</div>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat-item">
        <div class="hero-stat-val">GBD</div>
        <div class="hero-stat-lbl">maior estudo epi<br/>do mundo</div>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat-item">
        <div class="hero-stat-val">150+</div>
        <div class="hero-stat-lbl">países cobertos<br/>pelos nossos estudos</div>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat-item">
        <div class="hero-stat-val">600+</div>
        <div class="hero-stat-lbl">citações em artigos feitos<br/>por integrantes do LabEpi</div>
      </div>
    </div>
  </div>
</section>

<!-- ── NOSSA ORIGEM ── -->
<section class="origem sep">
  <svg class="origem-bg-deco" viewBox="0 0 400 400" fill="none" aria-hidden="true">
    <circle cx="200" cy="200" r="180" stroke="#99ffcd" stroke-width="1.5" stroke-dasharray="6 5"/>
    <circle cx="200" cy="200" r="120" stroke="#99ffcd" stroke-width="1.5" stroke-dasharray="6 5"/>
    <circle cx="200" cy="200" r="60" stroke="#99ffcd" stroke-width="1.5"/>
    <path d="M200 20 A180 180 0 0 1 380 200" stroke="#99ffcd" stroke-width="6" fill="none" stroke-linecap="round" opacity="0.6"/>
  </svg>

  <div class="container">
    <div class="origem-grid">
      <div class="origem-content">
        <div class="section-tag">Nossa história</div>
        <h2 class="section-title">
          Nascemos de uma<br/>
          <span class="mint">frustração legítima.</span>
        </h2>
        <p>
          Lucas Santos estava treinando pesquisadores em um dos estudos mais relevantes da saúde global, o <em>Global Burden of Disease</em>, quando percebeu um padrão consistente: profissionais brilhantes, com formação sólida em medicina ou enfermagem, chegavam sem saber como planejar um estudo epidemiológico do zero.
        </p>
        <p>
          O problema não era falta de inteligência. Era falta de uma ponte entre o que os cursos de graduação ensinam, teoria e nomenclatura, e o que a prática científica real exige: decisões metodológicas, análise crítica de vieses, interpretação de dados e comunicação de resultados.
        </p>
        <p>
          O LabEpi nasceu para ser essa ponte. Uma plataforma de formação real, baseada em evidências, construída por quem trabalha no front da pesquisa epidemiológica global.
        </p>
      </div>

      <div class="origem-visual">
        <div class="timeline-item">
          <div class="timeline-left">
            <div class="timeline-dot">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 2"/></svg>
            </div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-body">
            <div class="timeline-year">Antes de 2026</div>
            <div class="timeline-title">O gap identificado</div>
            <div class="timeline-desc">Lucas percebe sistematicamente a falta de formação metodológica prática nos pesquisadores em formação que treinava no GBD.</div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-left">
            <div class="timeline-dot active">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7 L6 10 L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-body">
            <div class="timeline-year">2026</div>
            <div class="timeline-title">O LabEpi nasce</div>
            <div class="timeline-desc">Lançamento da plataforma com foco exclusivo em epidemiologia aplicada: blog, ebooks e consultoria metodológica personalizada.</div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-left">
            <div class="timeline-dot future">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 3 V7 L10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>
          <div class="timeline-body">
            <div class="timeline-year">2026 →</div>
            <div class="timeline-title">Cursos em vídeo</div>
            <div class="timeline-desc">Lançamento dos primeiros cursos completos em vídeo: Pós-Graduação, Metodologia, Estatística e GBD.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── MVV ── -->
<section class="mvv sep">
  <div class="container">
    <div class="mvv-header">
      <div class="section-tag">Fundamentos</div>
      <h2 class="section-title">Missão, <span class="mint">visão e valores.</span></h2>
      <p class="section-body" style="margin: 16px auto 0; text-align:center;">Os princípios que guiam cada decisão do LabEpi, do conteúdo que publicamos ao produto que construímos.</p>
    </div>

    <div class="mvv-grid">
      <div class="mvv-card">
        <div class="mvv-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 3"/>
            <circle cx="11" cy="11" r="3" fill="currentColor"/>
            <path d="M11 3 L11 7 M11 15 L11 19 M3 11 L7 11 M15 11 L19 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
          </svg>
        </div>
        <div class="mvv-label">Missão</div>
        <h3>Democratizar a formação em epidemiologia aplicada</h3>
        <p>Tornar o conhecimento metodológico rigoroso acessível a todo pesquisador em formação no Brasil, sem concessões ao rigor científico e sem barreiras desnecessárias ao aprendizado.</p>
      </div>

      <div class="mvv-card">
        <div class="mvv-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <path d="M1 11 C5 4 8 2 11 2 C14 2 17 4 21 11 C17 18 14 20 11 20 C8 20 5 18 1 11Z" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="11" cy="11" r="3.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <div class="mvv-label">Visão</div>
        <h3>Ser a referência nacional em ciência epidemiológica</h3>
        <p>Em 2028, o LabEpi é a primeira plataforma que qualquer estudante ou pesquisador brasileiro busca quando precisa aprender a fazer ciência de verdade, da hipótese à publicação.</p>
      </div>

      <div class="mvv-card">
        <div class="mvv-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <path d="M11 2 L13.5 8.5 L20.5 8.5 L14.9 12.7 L17.1 19.5 L11 15.5 L4.9 19.5 L7.1 12.7 L1.5 8.5 L8.5 8.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="mvv-label">Valores</div>
        <h3>Os princípios que não negociamos</h3>
        <p>Rigor sem pedantismo. Acessibilidade sem superficialidade. Evidência acima de opinião. Transparência sobre o que sabemos (e o que ainda não sabemos).</p>
      </div>
    </div>

    <div class="valores-row">
      <div class="valor-pill"><span class="valor-pill-dot"></span>Evidência científica</div>
      <div class="valor-pill"><span class="valor-pill-dot"></span>Rigor metodológico</div>
      <div class="valor-pill"><span class="valor-pill-dot"></span>Didática prática</div>
      <div class="valor-pill"><span class="valor-pill-dot"></span>Transparência</div>
      <div class="valor-pill"><span class="valor-pill-dot"></span>Aplicabilidade real</div>
      <div class="valor-pill"><span class="valor-pill-dot"></span>Autonomia do aprendiz</div>
    </div>
  </div>
</section>

<!-- ── MANIFESTO ── -->
<section class="manifesto sep">
  <div class="container">
    <div class="manifesto-inner">
      <div class="section-tag">Nosso manifesto</div>

      <div class="manifesto-quote">
        "A epidemiologia não é disciplina de pós-graduação.<br/>
        É a <span class="mint">linguagem da saúde pública.</span><br/>
        E toda linguagem pode ser ensinada."
      </div>

      <p class="manifesto-body">
        Acreditamos que a maioria dos pesquisadores em formação no Brasil podem transpor o déficit de acesso que enfrentam atualmente. Acesso a conteúdo que conecte teoria e prática, que cite fontes reais, que mostre o caminho entre uma ideia de pesquisa e um artigo publicado. O LabEpi existe para ser esse acesso.
      </p>

      <div class="manifesto-pillars">
        <div class="pillar-card">
          <div class="pillar-num">01</div>
          <h4>Informação baseada em evidências</h4>
          <p>Todo dado que publicamos tem fonte verificável. Nada de "estudos mostram" sem mostrar quais estudos.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-num">02</div>
          <h4>Metodologia que você usa amanhã</h4>
          <p>Não ensinamos o que é um estudo de coorte, ensinamos como montar, executar e analisar um.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-num">03</div>
          <h4>Comunidade unida</h4>
          <p>Nosso foco é unir pesquisadores e estudantes que se ajudam, que questionam e que produzem ciência juntos.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── EQUIPE ── -->
<section class="equipe sep">
  <div class="container">
    <div class="equipe-header">
      <div class="section-tag">Quem faz acontecer</div>
      <h2 class="section-title">Um time pequeno com<br/><span class="mint">foco cirúrgico.</span></h2>
      <p>Cada pessoa no LabEpi tem uma responsabilidade clara e um papel insubstituível. Ninguém faz de tudo: todo mundo faz muito bem o que é seu.</p>
    </div>

    <div class="equipe-grid">
      <div class="membro-card">
        <div class="membro-foto">
          <img src="/assets/images/lucas-santos.jpg" alt="Lucas Santos" loading="lazy" decoding="async" />
          <div class="membro-foto-deco"></div>
        </div>
        <div class="membro-body">
          <h3>Lucas Santos</h3>
          <div class="membro-role">Epidemiologista · Fundador e Professor</div>
          <p class="membro-bio">Epidemiologista com atuação ativa no Global Burden of Disease (GBD/IHME), o maior estudo epidemiológico do mundo, publicado em The Lancet. É o responsável pelo conteúdo científico do LabEpi, artigos, aulas e consultorias.</p>
          <div class="membro-tags">
            <span class="membro-tag">Epidemiologia</span>
            <span class="membro-tag">GBD / IHME</span>
            <span class="membro-tag">Metodologia</span>
          </div>
        </div>
      </div>

      <div class="membro-card">
        <div class="membro-foto">
          <img src="/assets/images/gabrielolegario.jpg" alt="Gabriel Olegário" loading="lazy" decoding="async" />
          <div class="membro-foto-deco"></div>
        </div>
        <div class="membro-body">
          <h3>Gabriel Olegário</h3>
          <div class="membro-role">Cofundador · Plataforma &amp; Dados</div>
          <p class="membro-bio">Responsável pela plataforma digital do LabEpi, do site ao conteúdo que chega até você. Garante que o conhecimento científico produzido pelo Lucas seja encontrável, acessível e bem apresentado.</p>
          <div class="membro-tags">
            <span class="membro-tag">Plataforma</span>
            <span class="membro-tag">Estratégia digital</span>
            <span class="membro-tag">Conteúdo</span>
          </div>
        </div>
      </div>

      <div class="membro-card">
        <div class="membro-foto">
          <img src="/assets/images/andresoares.jpeg" alt="André Soares" loading="lazy" decoding="async" />
          <div class="membro-foto-deco"></div>
        </div>
        <div class="membro-body">
          <h3>André Soares</h3>
          <div class="membro-role">Cofundador &amp; Produção Visual</div>
          <p class="membro-bio">Responsável pela identidade visual e produção audiovisual do LabEpi. Garante que cada material, do slide de aula ao vídeo publicado, comunique com clareza e coerência visual.</p>
          <div class="membro-tags">
            <span class="membro-tag">Design</span>
            <span class="membro-tag">Vídeo</span>
            <span class="membro-tag">Identidade visual</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── IMPACTO E CONTEXTO ── -->
<section class="impacto sep">
  <div class="container">
    <div class="impacto-header">
      <div>
        <div class="section-tag">Contexto e impacto</div>
        <h2 class="section-title">Números que<br/><span class="mint">justificam existir.</span></h2>
      </div>
      <p class="section-body">O mercado de formação em saúde no Brasil é imenso e mal atendido. Estes são os dados que nos motivam.</p>
    </div>

    <div class="impacto-numbers">
      <div class="impacto-card">
        <div class="impacto-val">2,3M</div>
        <div class="impacto-lbl">estudantes de saúde ativos no Brasil</div>
      </div>
      <div class="impacto-card">
        <div class="impacto-val">150+</div>
        <div class="impacto-lbl">países com dados no estudo GBD</div>
      </div>
      <div class="impacto-card">
        <div class="impacto-val">600+</div>
        <div class="impacto-lbl">citações em artigos feitos por integrantes do LabEpi</div>
      </div>
      <div class="impacto-card">
        <div class="impacto-val">#1</div>
        <div class="impacto-lbl">posicionamento-alvo em epidemiologia aplicada no Google BR</div>
      </div>
    </div>

    <div class="impacto-bar">
      <div class="impacto-bar-text">
        <h3>Conteúdo baseado nas melhores fontes da área</h3>
        <p>Todo artigo, aula e material do LabEpi cita fontes primárias de alto impacto, garantindo que o pesquisador aprenda com a mesma base que a academia usa.</p>
      </div>
      <div class="impacto-bar-logos">
        <div class="ref-badge">The Lancet</div>
        <div class="ref-badge">BMJ</div>
        <div class="ref-badge">The New England Journal of Medicine</div>
        <div class="ref-badge">JAMA</div>
        <div class="ref-badge">Journal of Clinical Epidemiology</div>
      </div>
    </div>
  </div>
</section>

<!-- ── CTA FINAL ── -->
<section class="cta-final sep">
  <div class="container">
    <div class="cta-final-inner">
      <canvas class="formulas-canvas" aria-hidden="true"></canvas>
      <div class="cta-final-glow" aria-hidden="true"></div>

      <div class="cta-final-content">
        <div class="cta-final-eyebrow">Conheça nosso trabalho</div>

        <h2>
          O LabEpi é construído<br/>
          <span class="mint">aula a aula, artigo a artigo.</span>
        </h2>

        <p>Explore o blog, acompanhe os conteúdos que publicamos semanalmente ou entre em contato se quiser conversar sobre pesquisa.</p>

        <div class="cta-actions">
          <a href="/blog/" class="btn-primary">Ver o Blog</a>
          <a href="/consultoria/" class="btn-secondary">Fale com a gente →</a>
        </div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.formulas-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}
.cta-final-content {
  position: relative;
  z-index: 1;
}
</style>

<script>
// Canvas animation — lifecycle managed for Astro View Transitions
let _canvasRaf = 0;
let _canvasResize: (() => void) | null = null;

// Clean up before page swap to avoid orphaned RAF loops
document.addEventListener('astro:before-swap', () => {
  cancelAnimationFrame(_canvasRaf);
  if (_canvasResize) { window.removeEventListener('resize', _canvasResize); _canvasResize = null; }
});

document.addEventListener('astro:page-load', () => {
  const canvas = document.querySelector<HTMLCanvasElement>('.formulas-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  const formulas = [
    'p < 0.05', 'χ²', 'μ ± σ', 'β₀ + β₁x', 'OR = 2.3',
    '95% IC', 'HR = 1.7', 'H₀: μ = 0', '∑xᵢ/n', 'RR = 0.8',
    'r = 0.94', 'α = 0.05', 'logit(p)', 'e^β', 'N(0,1)',
    'df = n−1', 'IC 95%', 'σ²', 'Δ = β', 'p-valor',
  ];

  type Particle = {
    text: string; x: number; y: number;
    vx: number; vy: number;
    opacity: number; size: number;
    life: number; maxLife: number;
  };

  let particles: Particle[] = [];
  let W = 0, H = 0;

  function resize() {
    const rect = canvas.parentElement!.getBoundingClientRect();
    W = canvas.width = rect.width;
    H = canvas.height = rect.height;
  }

  function spawn(randomY = false): Particle {
    return {
      text: formulas[Math.floor(Math.random() * formulas.length)],
      x: Math.random() * W,
      y: randomY ? Math.random() * H : H + 20,
      vx: (Math.random() - 0.5) * 0.2,
      vy: -(0.25 + Math.random() * 0.35),
      opacity: 0.05 + Math.random() * 0.09,
      size: 11 + Math.random() * 5,
      life: 0,
      maxLife: 500 + Math.random() * 400,
    };
  }

  function init() {
    particles = Array.from({ length: 20 }, () => {
      const p = spawn(true);
      p.life = Math.random() * p.maxLife;
      return p;
    });
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    if (particles.length < 20 && Math.random() < 0.015) {
      particles.push(spawn());
    }

    particles = particles.filter((p) => {
      p.life++;
      p.x += p.vx;
      p.y += p.vy;

      const fadeIn  = Math.min(1, p.life / 80);
      const fadeOut = Math.min(1, (p.maxLife - p.life) / 80);
      const alpha   = p.opacity * fadeIn * fadeOut;

      ctx.save();
      ctx.font = `${p.size}px monospace`;
      ctx.fillStyle = `rgba(153,255,205,${alpha})`;
      ctx.fillText(p.text, p.x, p.y);
      ctx.restore();

      return p.life < p.maxLife && p.y > -30;
    });

    _canvasRaf = requestAnimationFrame(draw);
  }

  resize();
  init();
  draw();

  _canvasResize = () => { cancelAnimationFrame(_canvasRaf); resize(); init(); _canvasRaf = requestAnimationFrame(draw); };
  window.addEventListener('resize', _canvasResize);
});
</script>
